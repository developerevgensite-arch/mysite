---
import "../styles/global.css";

const { title } = Astro.props
---

<html lang="en">
<head>

    <meta charset="UTF-8">
        
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        
    <title>{title}</title>
        
    <meta name="description" content="Reviews of the best hosting, VPN and WordPress tools to build fast and secure websites.">
    
    <meta name="robots" content="index, follow">

    <link rel="canonical" href={Astro.url.href} />
        
    <link rel="icon" type="image/svg+xml" href="/favicon2.svg" />

</head>

<body>

    <header class="header">

        <div class="logo">
        <a href="/">Tech<span>Review</span></a>
        </div>
        
        <button class="menu-toggle" aria-label="Menu">
        ☰
        </button>
        
        <nav class="menu" aria-label="Main navigation">
        
        <a href="/">Home</a>
        <a href="/hosting">Hosting</a>
        <a href="/vpn">VPN</a>
        <a href="/security">Security</a>
        <a href="/wordpress-tools">WordPress Tools</a>
        <a href="/about">About</a>
        
        </nav>
        
    </header>

<main>
<slot />
</main>

<footer>

    <nav class="footer-links">
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/privacy-policy">Privacy Policy</a>
    <a href="/affiliate-disclosure">Affiliate Disclosure</a>
    </nav>
    
    <p class="disclosure">
    Disclosure: This page contains affiliate links. If you purchase through these links, we may earn a commission at no additional cost to you.
    </p>
    
    <p>© 2026 TechReview. All rights reserved.</p>
    
    </footer>

    <script>

        const toggle = document.querySelector(".menu-toggle");
        const menu = document.querySelector(".menu");
        
        toggle.addEventListener("click", () => {
        menu.classList.toggle("show");
        });
        
    </script>
</body>
</html>