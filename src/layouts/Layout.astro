---
const { title } = Astro.props
---

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>

<style>

body{
  margin:0;
  font-family: Arial, sans-serif;
  color:#222;
}

/* HEADER */

header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px 40px;
  border-bottom:1px solid #eee;
}

.logo{
  font-size:22px;
  font-weight:bold;
}

.logo span{
  color:#ff9900;
}

nav a{
  margin-left:20px;
  text-decoration:none;
  color:#333;
  font-weight:500;
}

nav a:hover{
  color:#ff9900;
}

/* MAIN */

main{
  max-width:1100px;
  margin:auto;
}

/* FOOTER */

footer{
  margin-top:80px;
  padding:30px;
  text-align:center;
  border-top:1px solid #eee;
  color:#666;
  font-size:14px;
}

</style>

</head>

<body>

<header>

<div class="logo">
Tech<span>Review</span>
</div>

<nav>
<a href="/">Home</a>
</nav>

</header>

<main>
<slot />
</main>

<footer>
<p>© 2026 TechReview. All rights reserved.</p>
</footer>

</body>
</html>