---
import Layout from "../../layouts/Layout.astro";
import reviews from "../../data/reviews.json";

export async function getStaticPaths() {

  const vpnReviews = reviews.filter(
    (review) => review.category === "vpn"
  );

  return vpnReviews.map((review) => ({
    params: { slug: review.slug },
    props: { review }
  }));

}

const { review } = Astro.props;
---

<Layout title={review.title}>

<section class="review-hero">

<h1>{review.title}</h1>

<p class="review-subtitle">
{review.description}
</p>

<div class="review-box">

<div class="review-product">
<h2>{review.name}</h2>

<a
href={review.affiliate}
target="_blank"
rel="nofollow sponsored"
class="review-btn"
>
Visit {review.name}
</a>

</div>

<div class="review-rating">
⭐ {review.rating} / 5
</div>

</div>

</section>

<section class="pros-cons">

<h2>Pros</h2>

<ul>
<li>Strong encryption to protect your online activity</li>
<li>Access to geo‑restricted streaming content</li>
<li>Apps for desktop and mobile devices</li>
</ul>

<h2>Cons</h2>

<ul>
<li>Best speeds usually on nearby servers only</li>
</ul>

</section>

<style>

.review-hero{
max-width:1000px;
margin:auto;
padding:40px 20px 0px;
}

.review-subtitle{
font-size:18px;
color:#555;
margin-bottom:30px;
}

.review-box{
display:flex;
justify-content:space-between;
align-items:center;
background:#fff;
border-radius:12px;
padding:30px;
box-shadow:0 5px 20px rgba(0,0,0,0.05);
margin-bottom:0px;
}

.review-product h2{
margin-bottom:20px;
}

.review-btn{
display:inline-block;
background:#ff8a00;
color:white;
padding:14px 26px;
border-radius:8px;
text-decoration:none;
font-weight:bold;
transition:0.2s;
min-width:150px;
text-align:center;
cursor:pointer;
box-shadow:0 4px 10px rgba(0,0,0,0.08);
}

.review-btn:hover{
background:#e67600;
}

.review-rating{
font-size:22px;
font-weight:bold;
color:#2e7d32;
}

.pros-cons{
max-width:1000px;
margin:auto;
padding:10px 20px;
}

.pros-cons h2{
margin-top:40px;
}

.pros-cons ul{
margin-top:10px;
padding-left:20px;
}

</style>

</Layout>
