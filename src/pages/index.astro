---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Best Laptop for Students">

<section class="hero">
  <h1>Best Laptop for Students in 2026</h1>
  <p>Lightweight, fast, and perfect for studying. We reviewed dozens of laptops to find the best option.</p>

  <a class="btn" href="https://www.amazon.com/" target="_blank">
    Check Current Price
  </a>
</section>

<section class="product">
  <img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=800" alt="Laptop">

  <div>
    <h2>Top Pick: UltraBook Pro</h2>

    <ul>
      <li>✔ 14" Retina Display</li>
      <li>✔ 16GB RAM</li>
      <li>✔ 10 hours battery</li>
      <li>✔ Lightweight for students</li>
    </ul>

    <a class="btn" href="https://www.amazon.com/" target="_blank">
      View Deal
    </a>
  </div>
</section>

<style>

.hero {
  text-align: center;
  padding: 30px 20px;
}

.hero h1 {
  font-size: 40px;
}

.hero p {
  max-width: 600px;
  margin: 20px auto;
}

.product {
  display: flex;
  gap: 40px;
  padding: 40px;
  align-items: center;
}

.product img {
  width: 400px;
  border-radius: 10px;
}

.btn {
  display: inline-block;
  background: #ff9900;
  color: white;
  padding: 14px 26px;
  border-radius: 6px;
  text-decoration: none;
  margin-top: 20px;
  font-weight: bold;
}

.btn:hover {
  background: #e88900;
}

@media (max-width: 800px) {

.product {
  flex-direction: column;
}

.product img {
  width: 100%;
}

.hero h1 {
  font-size: 30px;
}

}

</style>
