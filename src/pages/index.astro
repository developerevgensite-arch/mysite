---
import Layout from '../layouts/Layout.astro';
import reviews from '../data/reviews.json';

const hosting = reviews.filter(r => r.category === "hosting");
const vpn = reviews.filter(r => r.category === "vpn");
const wordpress = reviews.filter(r => r.category === "wordpress-tools");
---

<Layout title="Best Digital Tools Reviews">

<section class="hero hero-grid">

<div class="hero-text">

<h1>Best Digital Tools and Services in 2026</h1>

<p class="hero-subtitle">
We review the best hosting, VPN and digital tools to help you create websites, stay secure online and grow your projects.
</p>

<div class="hero-buttons">

<a href="/hosting" class="btn hero-btn">
See Best Hosting
</a>

<a href="/vpn" class="btn hero-btn-outline">
Best VPN Tools
</a>

</div>

</div>

<div class="hero-image">
<img src="/hero-tools.png" alt="Digital tools illustration">
</div>

</section>


<section class="featured-hosting">

<div class="featured-card">

<div class="featured-badge">
Editor's Choice
</div>

<h2>Hostinger</h2>

<p>
Best hosting for beginners with fast performance and affordable pricing.
</p>

<a href="/hosting/hostinger" class="btn">
Visit Hostinger
</a>

</div>

</section>


<h2>Best Hosting</h2>

<div class="tools-grid">

{hosting.map((item) => (

<div class="tool-card">

<h3>{item.name}</h3>

<p>
{item.description}
</p>

<a href={`/${item.category}/${item.slug}`} class="btn">
Read Review
</a>

</div>

))}

</div>



<h2>Best VPN</h2>

<div class="tools-grid">

{vpn.map((item) => (

<div class="tool-card">

<h3>{item.name}</h3>

<p>
{item.description}
</p>

<a href={`/${item.category}/${item.slug}`} class="btn">
Read Review
</a>

</div>

))}

</div>



<h2>WordPress Tools</h2>

<div class="tools-grid">

{wordpress.map((item) => (

<div class="tool-card">

<h3>{item.name}</h3>

<p>
{item.description}
</p>

<a href={`/${item.category}/${item.slug}`} class="btn">
Read Review
</a>

</div>

))}

</div>

</Layout>